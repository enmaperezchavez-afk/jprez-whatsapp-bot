{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "{.claude/skills/**/*.md,data/icdv-history.json}"
      }
    },
    {
      "src": "api/pdf.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/img.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/followup.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/dashboard.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/health.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/inventory.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ".claude/skills/**/*.md"
      }
    },
    {
      "src": "api/price-list.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "{.claude/skills/**/*.md,public/logos/**,src/documents/fonts/**}"
      }
    },
    {
      "src": "api/icdv.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "data/icdv-history.json"
      }
    },
    {
      "src": "api/tasa.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/pdf",
      "dest": "/api/pdf.js"
    },
    {
      "src": "/api/img",
      "dest": "/api/img.js"
    },
    {
      "src": "/api/followup",
      "dest": "/api/followup.js"
    },
    {
      "src": "/api/dashboard",
      "dest": "/api/dashboard.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/inventory",
      "dest": "/api/inventory.js"
    },
    {
      "src": "/api/price-list",
      "dest": "/api/price-list.js"
    },
    {
      "src": "/api/icdv",
      "dest": "/api/icdv.js"
    },
    {
      "src": "/api/tasa",
      "dest": "/api/tasa.js"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/health",
      "dest": "/public/health.html"
    }
  ],
  "crons": [
    {
      "path": "/api/followup",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/icdv?cron=1",
      "schedule": "0 14 23-31 * *"
    },
    {
      "path": "/api/tasa?cron=1",
      "schedule": "0 21 * * *"
    }
  ]
}
