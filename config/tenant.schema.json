{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tenant Config — MATEO V6 (F1)",
  "description": "Contrato de la config declarativa por tenant. FAIL-CLOSED de onboarding: una config que no cumple este schema NO arranca. En F1 el schema es documental y lo verifica el test de paridad; en F2 el loader lo valida en runtime.",
  "type": "object",
  "required": ["tenant_id", "prompt_version", "vendedor", "canal", "proyectos", "doctrina", "integraciones"],
  "properties": {
    "tenant_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,30}$" },
    "prompt_version": { "type": "integer", "minimum": 1 },
    "vendedor": {
      "type": "object",
      "required": ["nombre", "empresa", "tono", "idiomas"],
      "properties": {
        "nombre": { "type": "string", "minLength": 2 },
        "empresa": { "type": "string", "minLength": 2 },
        "tono": { "type": "string" },
        "idiomas": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "director": { "type": "string" }
      }
    },
    "canal": {
      "type": "object",
      "required": ["phone_number_id_env", "admin_phones"],
      "properties": {
        "phone_number_id_env": { "type": "string", "description": "NOMBRE de la env var — los secretos jamás viven en la config" },
        "admin_phones": { "type": "array", "items": { "type": "string", "pattern": "^\\d{10,15}$" }, "minItems": 1 },
        "dominio_publico": { "type": "string", "format": "uri" }
      }
    },
    "proyectos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "nombre", "ubicacion", "en_construccion", "moneda", "reserva", "sheet_tab", "theme", "logo"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,30}$" },
          "nombre": { "type": "string" },
          "ubicacion": { "type": "string" },
          "entrega": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "en_construccion": { "type": "boolean" },
          "moneda": { "enum": ["USD", "DOP"] },
          "plan_base": {
            "type": ["array", "null"],
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "description": "[inicial, completivo, entrega] — DEBE sumar 100. null = sin plan de cuotas (entrega inmediata)."
          },
          "margenes": { "type": "array", "items": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 } },
          "reserva": { "type": "number", "exclusiveMinimum": 0 },
          "calc_key_legacy": { "type": ["string", "null"], "description": "puente F1-F3 al sistema viejo de keys; muere en F3" },
          "etapa_legacy": { "type": "string" },
          "sheet_tab": { "type": "string" },
          "theme": { "type": "string" },
          "logo": { "type": "string" },
          "brochure_drive_id": { "type": "string" }
        }
      }
    },
    "doctrina": {
      "type": "object",
      "required": ["descuento_autonomo_max_usd", "escalera", "cubetas", "reglas_duras"],
      "properties": {
        "descuento_autonomo_max_usd": { "type": "number", "minimum": 0 },
        "escalera": {
          "type": "object",
          "required": ["concesion_inicial_usd", "condicion_primero", "revelar_tope"],
          "properties": {
            "concesion_inicial_usd": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "condicion_primero": { "const": true },
            "revelar_tope": { "const": false },
            "revelar_mecanica": { "const": false }
          }
        },
        "cubetas": { "type": "object" },
        "reglas_duras": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object", "required": ["id", "texto"] }
        },
        "handoff_canonico_es": { "type": "string" }
      }
    },
    "integraciones": { "type": "object" }
  }
}
